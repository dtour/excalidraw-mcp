{
  "name": "excalidraw-mcp",
  "version": "0.1.0",
  "description": "MCP server for reading, creating, modifying, and rendering Excalidraw diagrams",
  "type": "module",
  "bin": {
    "excalidraw-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --external @resvg/resvg-js",
    "dev": "bun src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "lz-string": "^1.5.0",
    "nanoid": "^5.1.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/lz-string": "^1.5.0",
    "@types/node": "^22.0.0",
    "fast-check": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
